
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth.uid != null;
    }

    function isFirstAdmin() {
      // Correctly checks if the 'admins' collection is empty.
      // This function requires the calling user to have 'list' permission on the 'admins' collection.
      return list(/databases/$(database)/documents/admins, 1).size() == 0;
    }

    function isAdmin() {
      // Fast, non-recursive check for admin privileges.
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // A user can always read their own profile.
    // An admin can read/update any user's profile.
    match /users/{userId} {
      allow create: if isAuth();
      allow get, update: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admins collection rules
    match /admins/{userId} {
      // Any authenticated user can check for an admin's existence and list the collection.
      // The 'list' permission is required for the isFirstAdmin() function to work correctly.
      allow get, list: if isAuth();
      
      // The FIRST user can CREATE their own admin document, securing the bootstrap process.
      allow create: if isFirstAdmin() && isOwner(userId);
      
      // Existing admins can update or delete other admin documents.
      allow update, delete: if isAdmin();
    }
    
    // Settings collections are admin-only for writes.
    match /app_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
     match /product_categories/{categoryId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /expense_categories/{categoryId} {
       allow read: if isAuth();
       allow write: if isAdmin();
    }

    // Customers can be managed by any authenticated user.
    match /customers/{customerId} {
      allow read, write: if isAuth();
    }
    
    // Suppliers can only be created/edited by Admins.
    match /suppliers/{supplierId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // Products can be read by anyone, but stock updates are allowed for sales/purchases,
    // while creation/deletion is admin-only.
    match /products/{productId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAuth(); // Allows for stock updates from sales, purchases, and transfers
    }

    // Selling forms can be created/updated by any user, but only deleted by Admins.
    match /selling_forms/{sellingFormId} {
      allow read, create, update: if isAuth();
      allow delete: if isAdmin();
      
      // Subcollections follow the parent's delete logic.
      match /selling_form_products/{productId} {
        allow read, create, update: if isAuth();
        allow delete: if isAdmin();
      }
      match /payments/{paymentId} {
        allow read, create, update: if isAuth();
        allow delete: if isAdmin();
      }
    }
    
    // Collection group reads are allowed for all authenticated users.
    match /selling_form_products/{docId} {
        allow get, list: if isAuth();
    }

    // Buying forms are entirely admin-only.
    match /buying_forms/{buyingFormId} {
      allow read, write: if isAdmin();

      match /buying_form_products/{productId} {
        allow read, write: if isAdmin();
      }
    }
    
    match /buying_form_products/{docId} {
        allow get, list: if isAuth();
    }
    
    // Expenses are admin-only.
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    // Stock movements can be initiated by any authenticated user (e.g., during a sale or transfer).
    match /stock_movements/{movementId} {
      allow read, write: if isAuth();
    }
  }
}
