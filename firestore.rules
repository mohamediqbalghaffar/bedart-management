rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if request.auth.uid != null;
    }
    
    // Allow logged-in users to read from collections
    match /customers/{customerId} {
      allow read, write: if request.auth.uid != null;
    }
    match /suppliers/{supplierId} {
      allow read, write: if request.auth.uid != null;
    }
    match /products/{productId} {
      allow read, write: if request.auth.uid != null;
    }
     match /product_categories/{categoryId} {
      allow read, write: if request.auth.uid != null;
    }
    match /expense_categories/{categoryId} {
       allow read, write: if request.auth.uid != null;
    }
     match /app_settings/{docId} {
      allow read, write: if request.auth.uid != null;
    }

    // Selling forms and their subcollections
    match /selling_forms/{sellingFormId} {
      allow read, write: if request.auth.uid != null;
    }
    match /selling_forms/{sellingFormId}/products/{productId} {
      allow read, write: if request.auth.uid != null;
    }
    match /selling_forms/{sellingFormId}/payments/{paymentId} {
      allow read, write: if request.auth.uid != null;
    }

    // Buying forms and their subcollections
    match /buying_forms/{buyingFormId} {
      allow read, write: if request.auth.uid != null;
    }
    match /buying_forms/{buyingFormId}/products/{productId} {
      allow read, write: if request.auth.uid != null;
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if request.auth.uid != null;
    }

    // Stock Movements
    match /stock_movements/{movementId} {
      allow read, write: if request.auth.uid != null;
    }
  }
}
