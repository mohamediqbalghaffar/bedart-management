/**
 * Core Philosophy: This ruleset enforces a strict Role-Based Access Control (RBAC) model
 * for a small business CRM. There are three roles: 'Admin', 'Data Manager', and 'Salesman'.
 * Admins and Data Managers have broad access to all data, including financial and inventory
 * information. Salesmen have highly restricted access, limited primarily to creating and
 * managing the sales forms they are responsible for.
 *
 * Data Structure: The data is organized into flat, top-level collections (e.g., /selling_forms,
 * /products, /expenses) to segregate data by function. This structure simplifies rule logic,
 * as permissions can be applied directly to entire collections based on user roles.
 *
 * Key Security Decisions:
 * - Default Deny: All access is denied by default. Permissions are explicitly granted.
 * - Role-Based Authorization: All permissions are checked against the user's role, which is
 *   stored in their /users/{userId} document. This requires a `get` call to the user's
 *   profile for most operations, centralizing the authorization logic.
 * - No User Enumeration: Listing documents in the `/users` collection is disallowed to protect
 *   user privacy and prevent enumeration attacks.
 * - Salesman Restrictions: Salesmen can only create and manage their own sales documents.
 *   They are blocked from viewing or modifying financial, purchasing, or inventory data.
 *
 * Denormalization for Authorization:
 * - User Roles: A user's role is stored on their `/users/{userId}` document. Rules use `get()`
 *   to fetch this role for authorization checks across the database.
 * - Document Ownership: For a 'Salesman' to manage only their own sales forms, each document
 *   in the `/selling_forms` collection MUST have a `creatorId` field containing the UID of the
 *   user who created it. This denormalized field is critical for enforcing ownership-based
- *   rules for `get`, `update`, and `delete` operations without costly queries.
 *
 * Structural Segregation: The use of distinct top-level collections for different data types
 * (e.g., `selling_forms`, `buying_forms`, `expenses`) provides a clear and secure separation
 * of concerns, making it easy to apply broad, role-based permissions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for Authentication and Authorization
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function docExists() {
      return resource != null;
    }

    // Fetches the requesting user's role from their user document.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'Admin';
    }

    function isDataManager() {
      return isSignedIn() && getUserRole() == 'Data Manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isDataManager();
    }

    function isSalesman() {
      return isSignedIn() && getUserRole() == 'Salesman';
    }

    /**
     * @description Manages user profiles and roles. A user can create their own profile,
     * but only Admins/Managers can modify roles or other users' data.
     * @path /users/{userId}
     * @allow (create) A new user signing up: `request.auth.uid == userId`.
     * @deny (list) Any user trying to list all other users in the system.
     * @principle Enforces self-creation of profiles and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdminOrManager();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && docExists() && request.resource.data.role == resource.data.role) || (isAdminOrManager() && docExists());
      allow delete: if isAdminOrManager() && docExists();
    }

    /**
     * @description Stores sales forms. Admins/Managers have full access. Salesmen can
     * create forms and can only read/update forms they created.
     * @path /selling_forms/{sellingFormId}
     * @allow (create) A Salesman creating a new form for a customer.
     * @deny (delete) A Salesman trying to delete a form, even one they created.
     * @principle Implements role-based access combined with document ownership for the Salesman role.
     */
    match /selling_forms/{sellingFormId} {
      allow get: if (isAdminOrManager()) || (isSalesman() && docExists() && resource.data.creatorId == request.auth.uid);
      allow list: if isAdminOrManager();
      allow create: if (isAdminOrManager() || isSalesman()) && request.resource.data.creatorId == request.auth.uid;
      allow update: if (docExists() && request.resource.data.creatorId == resource.data.creatorId) && (isAdminOrManager() || (isSalesman() && resource.data.creatorId == request.auth.uid));
      allow delete: if isAdminOrManager() && docExists();

      /**
       * @description Stores payments related to a specific selling form. Access is
       * inherited from the parent selling form.
       * @path /selling_forms/{sellingFormId}/payments/{paymentId}
       * @allow (create) A Salesman adding a payment to a form they created.
       * @deny (list) A Salesman trying to list payments for a form they did not create.
       * @principle Secures a subcollection by checking permissions on the parent document.
       */
      match /payments/{paymentId} {
        function isParentFormOwner() {
          let parentForm = get(/databases/$(database)/documents/selling_forms/$(sellingFormId));
          return parentForm.data.creatorId == request.auth.uid;
        }

        allow get, list: if isAdminOrManager() || (isSalesman() && isParentFormOwner());
        allow create: if (isAdminOrManager() || (isSalesman() && isParentFormOwner())) && request.resource.data.sellingFormId == sellingFormId;
        allow update, delete: if (isAdminOrManager() || (isSalesman() && isParentFormOwner())) && docExists();
      }

      /**
       * @description Stores products linked to a specific selling form. Access is
       * inherited from the parent selling form.
       * @path /selling_forms/{sellingFormId}/products/{productSellingFormId}
       * @allow (create) An Admin adding a product to an existing sales form.
       * @deny (update) A Salesman trying to change product details on another salesman's form.
       * @principle Secures a subcollection by checking permissions on the parent document.
       */
      match /products/{productSellingFormId} {
        function isParentFormOwner() {
          let parentForm = get(/databases/$(database)/documents/selling_forms/$(sellingFormId));
          return parentForm.data.creatorId == request.auth.uid;
        }

        allow get, list: if isAdminOrManager() || (isSalesman() && isParentFormOwner());
        allow create: if (isAdminOrManager() || (isSalesman() && isParentFormOwner())) && request.resource.data.sellingFormId == sellingFormId;
        allow update, delete: if (isAdminOrManager() || (isSalesman() && isParentFormOwner())) && docExists();
      }
    }

    /**
     * @description Stores buying forms for purchasing from suppliers. Restricted to
     * Admins and Data Managers who handle inventory and purchasing.
     * @path /buying_forms/{buyingFormId}
     * @allow (create) An Admin creating a new purchase order from a supplier.
     * @deny (get) A Salesman trying to view purchasing costs.
     * @principle Restricts access to sensitive business data based on user role.
     */
    match /buying_forms/{buyingFormId} {
      allow get, list, create, update, delete: if isAdminOrManager();

      /**
       * @description Stores products linked to a specific buying form. Access is
       * restricted to Admins and Data Managers.
       * @path /buying_forms/{buyingFormId}/products/{productBuyingFormId}
       * @allow (create) A Data Manager adding products received from a supplier.
       * @deny (get) A Salesman trying to view any data in this subcollection.
       * @principle Secures a subcollection by enforcing the parent collection's strict role-based permissions.
       */
      match /products/{productBuyingFormId} {
        allow get, list, update, delete: if isAdminOrManager();
        allow create: if isAdminOrManager() && request.resource.data.buyingFormId == buyingFormId;
      }
    }

    /**
     * @description Stores all business expenses. Access is restricted to Admins
     * and Data Managers for financial oversight.
     * @path /expenses/{expenseId}
     * @allow (create) A Data Manager logging a new delivery expense.
     * @deny (list) A Salesman trying to view the company's expense records.
     * @principle Restricts access to sensitive financial data based on user role.
     */
    match /expenses/{expenseId} {
      allow get, list, create, update, delete: if isAdminOrManager();
    }

    /**
     * @description Stores the master list of all products. Restricted to Admins
     * and Data Managers who manage inventory.
     * @path /products/{productId}
     * @allow (update) An Admin updating the stock location of a product.
     * @deny (create) A Salesman trying to add a new product to the system.
     * @principle Protects core business data (product catalog) from unauthorized modification.
     */
    match /products/{productId} {
      allow get, list, create, update, delete: if isAdminOrManager();
    }

    /**
     * @description Logs all stock movements (e.g., transfers between warehouse and
     * shop). Restricted to Admins and Data Managers.
     * @path /stock_movements/{stockMovementId}
     * @allow (create) A Data Manager recording a stock transfer from the warehouse to the showroom.
     * @deny (get) A Salesman trying to view inventory movement history.
     * @principle Protects inventory and operational data from unauthorized access.
     */
    match /stock_movements/{stockMovementId} {
      allow get, list, create, update, delete: if isAdminOrManager();
    }

    /**
     * @description Stores supplier information. Restricted to Admins and Data Managers
     * who handle purchasing.
     * @path /suppliers/{supplierId}
     * @allow (list) An Admin viewing the list of all approved suppliers.
     * @deny (create) A Salesman trying to add a new supplier.
     * @principle Protects business relationship data (suppliers) from unauthorized modification.
     */
    match /suppliers/{supplierId} {
      allow get, list, create, update, delete: if isAdminOrManager();
    }
  }
}
    