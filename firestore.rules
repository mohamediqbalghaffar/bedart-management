rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Users can read/write their own user document
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid != null;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }
    
    // Allow logged-in users to read from collections, but only admins can write/delete widely.
    match /customers/{customerId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }
    match /suppliers/{supplierId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }
    match /products/{productId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }
     match /product_categories/{categoryId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }
    match /expense_categories/{categoryId} {
       allow read, write: if request.auth.uid != null || isAdmin();
    }
     match /app_settings/{docId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }

    // Selling forms and their subcollections
    match /selling_forms/{sellingFormId} {
      allow read, write: if request.auth.uid != null || isAdmin();
      
      match /products/{productId} {
        allow read, write: if request.auth.uid != null || isAdmin();
      }
      match /payments/{paymentId} {
        allow read, write: if request.auth.uid != null || isAdmin();
      }
    }

    // Buying forms and their subcollections
    match /buying_forms/{buyingFormId} {
      allow read, write: if request.auth.uid != null || isAdmin();

      match /products/{productId} {
        allow read, write: if request.auth.uid != null || isAdmin();
      }
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }

    // Stock Movements
    match /stock_movements/{movementId} {
      allow read, write: if request.auth.uid != null || isAdmin();
    }
  }
}
