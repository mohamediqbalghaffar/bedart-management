rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: require authentication for all reads/writes
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Users collection: any authenticated user can read, only admins can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Product definitions: any authenticated user can read/write
    match /product_definitions/{productDefinitionId} {
      allow read, write: if request.auth != null;
    }
  }
}
